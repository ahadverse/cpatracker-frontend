{
  "name": "cpatracker-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:network-admin": "pnpm --filter network-admin dev",
    "dev:affiliate": "pnpm --filter affiliate dev",
    "dev:advertiser": "pnpm --filter advertiser dev",
    "dev:super-admin": "pnpm --filter super-admin dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  }
}
